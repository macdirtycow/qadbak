# Copy to .env.local on a DEDICATED test VPS only (never mareades / production).

SESSION_SECRET=generate-with-openssl-rand-base64-32
VIRTUALMIN_MOCK=false

VIRTUALMIN_URL=https://127.0.0.1:10000/virtual-server/remote.cgi
VIRTUALMIN_USER=root
VIRTUALMIN_PASS=

# Replace with your test VPS hostname (same as install panel hostname)
QADBAK_PUBLIC_HOST=panel-test.yourdomain.com
WEBMIN_UI_URL=https://panel-test.yourdomain.com:10000
VIRTUALMIN_UI_URL=https://panel-test.yourdomain.com:10000
USERMIN_UI_URL=https://panel-test.yourdomain.com:20000

PORT=3000
VIRTUALMIN_TLS_INSECURE=true

# Optional: domain on this VPS (test-api + file-helper sudo probe)
TEST_DOMAIN=v1test.example.com

# Optional: panel admin password for Playwright install E2E after updates (gitignored: .install-test.env)
# QADBAK_E2E_ADMIN_PASS=your-admin-password
