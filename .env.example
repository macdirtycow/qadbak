# VirtualMin Remote API (server-side only)
# Production on same host as Qadbak: often https://127.0.0.1:10000/... (see docs)
VIRTUALMIN_URL=https://localhost:10000/virtual-server/remote.cgi
VIRTUALMIN_USER=root
VIRTUALMIN_PASS=
# Set to true for local UI development without a VirtualMin server
VIRTUALMIN_MOCK=false
# Public URL of Webmin / VirtualMin UI (for login links; use your server hostname if not proxied)
# WEBMIN_UI_URL=https://your-server.example.com:10000
WEBMIN_UI_URL=https://localhost:10000
VIRTUALMIN_UI_URL=https://localhost:10000
# Usermin (often port 20000 on same host)
USERMIN_UI_URL=https://localhost:20000
# Public panel hostname (metadata + links): https://qadbak.com
QADBAK_PUBLIC_HOST=qadbak.com
# Self-signed VirtualMin TLS (dev only): export NODE_TLS_REJECT_UNAUTHORIZED=0

# Qadbak session secret (generate: openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-long-random-string

# Qadbak bind (for nginx reverse proxy)
PORT=3000
