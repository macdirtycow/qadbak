# Qadbak — native / independent hosting (recommended)
QADBAK_PROVISIONER=native
QADBAK_LEGACY_API_FALLBACK=false
QADBAK_DISABLE_LEGACY_PANEL=true
QADBAK_NATIVE_FEATURES=ssl,dns,mail,db,domain,backup,cron,aliases,redirects,features,logs,php,ftp,limits,lifecycle,mail-settings,mail-logs,imap,protected,shared,proxies,scripts,security,resellers

# Session secret (generate: openssl rand -base64 48; min 32 chars in production)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-16

# Security hardening (see docs/SECURITY.md)
# QADBAK_TRUST_PROXY=true
# QADBAK_HEALTH_MINIMAL=true
# QADBAK_COOKIE_SAMESITE=strict
# QADBAK_SESSION_MAX_AGE_HOURS=24
# QADBAK_REQUIRE_ADMIN_TOTP=true
# QADBAK_LOGIN_RATE_LIMIT=8
# QADBAK_API_RATE_LIMIT_PER_USER=300
# QADBAK_PASSWORD_MIN_LENGTH=12

# Mail (native Postfix + Dovecot)
QADBAK_MAIL_BACKEND=direct
# Hostname for MX / IMAP / SMTP (usually mail.example.com or server FQDN)
QADBAK_MAIL_HOST=mail.example.com
# Add MX + mail A to local BIND zones when possible (false = hints only)
QADBAK_MAIL_AUTODNS=true

# Public panel hostname (users open the panel here)
QADBAK_PUBLIC_HOST=panel.example.com

# Live demo (optional — e.g. demo.qadbak.com on same VPS)
# QADBAK_DEMO_HOST=demo.qadbak.com
# QADBAK_DEMO_ENABLED=true
# QADBAK_DEMO_READ_ONLY=true
# QADBAK_DEMO_USERNAME=demo
# QADBAK_DEMO_PASSWORD=DemoView2026!
# QADBAK_DEMO_SHOWCASE_DOMAIN=showcase.qadbak.com
# Auto-create panel.<domain> for every site on update (default off — one main panel URL)
# QADBAK_AUTO_PANEL_VHOSTS=false
# VPS public IP for website health / Cloudflare hints (optional)
# QADBAK_ORIGIN_IP=203.0.113.10

# Let's Encrypt contact (panel + client panel.* subdomains)
# QADBAK_LE_EMAIL=admin@example.com

# Qadbak bind (nginx reverse proxy)
PORT=3000

# License server (Premium commercial installs)
# Public license server URL (required for Premium activate/heartbeat)
QADBAK_LICENSE_SERVER=https://license.inveil.dev
# Optional: only when license API runs on THIS same VPS (e.g. dev). Do not set on panel-only hosts.
# QADBAK_LICENSE_SERVER_INTERNAL=http://127.0.0.1:8787
# Must match LICENSE_JWT_SECRET on the license server
# QADBAK_LICENSE_JWT_SECRET=
# QADBAK_LICENSE_JWT_SECRET=must-match-license-server-secret
# Premium heartbeat interval (hours; default 6 — use 12–24 for fewer outbound calls)
# QADBAK_HEARTBEAT_INTERVAL_HOURS=24
# Pause automatic heartbeats (manual "Heartbeat now" still works)
# QADBAK_DISABLE_HEARTBEAT_SCHEDULER=false
# Per-install API salt + license fingerprint (auto-set by ensure-install-salt.sh on install/update)

# Apple Push Notifications (iOS app alerts: SSL expiry, stopped containers)
# QADBAK_APNS_KEY_ID=ABCD1234
# QADBAK_APNS_TEAM_ID=TEAMID12
# QADBAK_APNS_KEY_PATH=/etc/qadbak/AuthKey_ABCD1234.p8
# QADBAK_APNS_BUNDLE_ID=com.qadbak.panel
# QADBAK_APNS_SANDBOX=false
# QADBAK_MOBILE_PUSH_INTERVAL_HOURS=6
# QADBAK_DISABLE_MOBILE_PUSH_SCHEDULER=false
# QADBAK_INSTALL_SALT=
# NEXT_PUBLIC_QADBAK_API_SALT=

# Local audit log retention (data/audit.log on your VPS only)
# QADBAK_AUDIT_MAX_LINES=50000
# QADBAK_AUDIT_RETENTION_DAYS=90

# VPS git branch (optional; default = current branch, cursor/* auto-maps to macdirtycow/*)
# QADBAK_GIT_BRANCH=main

# Local dev: cookies on http://localhost
# QADBAK_COOKIE_SECURE=false

# Native terminal WebSocket (pm2 app qadbak-terminal)
QADBAK_TERMINAL_WS_PORT=3001
QADBAK_TERMINAL_WS_HOST=127.0.0.1

# --- Legacy hybrid only (remote or local legacy hosting API API) ---
# QADBAK_LEGACY_API_URL=https://127.0.0.1:10000/virtual-server/remote.cgi
# QADBAK_LEGACY_API_USER=root
# QADBAK_LEGACY_API_PASS=
# QADBAK_LEGACY_API_MOCK=false
# QADBAK_LEGACY_API_TLS_INSECURE=true
# QADBAK_PROVISIONER=hybrid
# QADBAK_LEGACY_API_FALLBACK=true
# QADBAK_LEGACY_PANEL_URL=https://localhost:10000

# Local UI dev without a server (mock domains)
# QADBAK_LEGACY_API_MOCK=true
# QADBAK_COOKIE_SECURE=false

# Panel-only install (install/qadbak-install-panel.sh) — no native stack on this host
# QADBAK_INSTALL_MODE=panel-only
# QADBAK_PROVISIONER=hybrid
# QADBAK_LEGACY_API_MOCK=true
