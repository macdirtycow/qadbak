# VirtualMin Remote API (server-side only)
VIRTUALMIN_URL=https://localhost:10000/virtual-server/remote.cgi
VIRTUALMIN_USER=root
VIRTUALMIN_PASS=
# Set to true for local UI development without a VirtualMin server
VIRTUALMIN_MOCK=false
# Public URL of Webmin / VirtualMin UI (for login links)
WEBMIN_UI_URL=https://localhost:10000
VIRTUALMIN_UI_URL=https://localhost:10000
# Usermin (often port 20000 on same host)
USERMIN_UI_URL=https://localhost:20000
# Self-signed VirtualMin TLS (dev only): export NODE_TLS_REJECT_UNAUTHORIZED=0

# Nexmin session secret (generate: openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-long-random-string

# Nexmin bind (for nginx reverse proxy)
PORT=3000
